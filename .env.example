# Enterprise Knowledge Assistant - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# OPENAI API KEY (REQUIRED)
# ============================================================================
# Get your API key from: https://platform.openai.com/api/keys
# Looks like: sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-your-actual-api-key-here

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# ============================================================================
# CORS CONFIGURATION (Frontend URLs)
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///./enterprise_rag.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_rag

# ============================================================================
# VECTOR STORE CONFIGURATION
# ============================================================================
# Using ChromaDB for development, Pinecone for production
VECTOR_COLLECTION_NAME=enterprise_knowledge
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=

# ============================================================================
# RAG MODEL CONFIGURATION
# ============================================================================
# Embedding model for generating vector representations
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Generation model for answer synthesis
GENERATION_MODEL=gpt-3.5-turbo
# Upgrade to GPT-4 for higher accuracy (more expensive)
# GENERATION_MODEL=gpt-4

# Maximum tokens in generated response
MAX_TOKENS=500

# ============================================================================
# CHUNKING CONFIGURATION
# ============================================================================
# Chunk size in characters
CHUNK_SIZE=500

# Overlap between consecutive chunks
CHUNK_OVERLAP=100

# Chunking strategy: semantic, fixed, or hybrid
CHUNKING_STRATEGY=semantic

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================
# Search type: vector, keyword, or hybrid
SEARCH_TYPE=hybrid

# Weight for vector similarity in hybrid search (0.0-1.0)
VECTOR_WEIGHT=0.7

# Weight for keyword search in hybrid search (0.0-1.0)
KEYWORD_WEIGHT=0.3

# Number of top results to retrieve
TOP_K=5

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Enable query caching for faster repeated queries
ENABLE_CACHE=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. Never commit .env file to git - it contains secrets
# 2. Use .env for development only
# 3. Use environment variables or secrets management for production
# 4. Keep .env.example as a template (without actual secrets)
